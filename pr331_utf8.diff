-    # ------------------------------------------------------------------
-    # Step 4 ΓÇö Audit Logging
-    # ------------------------------------------------------------------
-
-    async def _audit_containment(
-        self,
-        report: ForensicsReport,
-        confirmed: bool,
-        results: list[ActionResult],
-        error: str = "",
-    ) -> None:
-        """Append a threat containment entry to the immutable audit log.
